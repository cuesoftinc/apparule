# apparule local development environment.
# Copy to .env and adjust as needed:  cp .env.example .env

# ── api/common (Go) ──
# Secret used to sign session JWTs. Use a strong, unique value outside local dev.
JWT_SECRET=dev-secret-change-me
# GCP / Firebase project id used for auth.
GOOGLE_CLOUD_PROJECT=apparule-local
# For full Firebase functionality, provide a service-account JSON and point to it:
# FIREBASE_CONFIG_PATH=/run/secrets/firebase-service-account.json

# ── web (Next.js) ──
# Base URL of the api-common service as seen from the browser.
NEXT_PUBLIC_BASE_URL=http://localhost:8080
